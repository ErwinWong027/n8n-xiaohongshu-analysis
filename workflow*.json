    {
      "parameters": {
        "batchSize": 5,
        "jsCode": "const inputItem = $input.first().json;\nconst authorId = inputItem.id;\nconst notesData = $('处理查询结果').first().json.notesData;\n\nconst processedNotes = notesData.map(note => ({\n  ...note,\n  author_id: authorId\n}));\n\nreturn processedNotes.map(note => ({ json: note }));"
      },
