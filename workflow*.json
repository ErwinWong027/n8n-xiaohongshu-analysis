      "id": "supabase-insert-notes",
      "name": "保存笔记数据",
      "type": "n8n-nodes-base.supabase",
      "typeVersion": 1,
      "position": [
        1820,
        300
      ],
      "credentials": {
        "supabaseApi": {
          "id": "CE5OpE28TxbcI9h2",
          "name": "Supabase account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const inputItem = $input.first().json;\nconst notesResults = $('保存笔记数据').all();\n\nlet success = true;\nlet message = '数据保存成功';\nlet details = {\n  authorSaved: false,\n  authorOperation: '',\n  notesSaved: 0,\n  totalNotes: 0\n};\n\ntry {\n  if (inputItem && inputItem.id) {\n    details.authorSaved = true;\n    details.authorOperation = inputItem._operation || 'unknown';\n  } else {\n    success = false;\n    message = '作者数据保存失败';\n  }\n\n  details.totalNotes = notesResults.length;\n  details.notesSaved = notesResults.filter(result => result.json && result.json.id).length;\n\n  if (details.notesSaved !== details.totalNotes) {\n    success = false;\n    message = `部分笔记数据保存失败，成功保存 ${details.notesSaved}/${details.totalNotes}`;\n  }\n\n} catch (error) {\n  success = false;\n  message = '数据处理过程中发生错误: ' + error.message;\n}\n\nreturn [{\n  json: {\n    success: success,\n    message: message,\n    details: details,\n    authorId: inputItem?.id || null,\n    timestamp: new Date().toISOString()\n  }\n}];"
      },
